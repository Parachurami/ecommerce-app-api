    "definitions": {
        "types.CreateProductParams": {
            "type": "object",
            "required": [
                "budget",
                "deliverables",
                "description",
                "duration",
                "expiration",
                "image",
                "name",
                "skills"
            ],
            "properties": {
                "budget": {
                    "type": "number"
                },
                "deliverables": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "description": {
                    "type": "string"
                },
                "duration": {
                    "type": "integer",
                    "example": 3600000000000
                },
                "expiration": {
                    "type": "integer",
                    "example": 3600000000000
                },
                "image": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "skills": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "types.LoginUserParams": {
            "type": "object",
            "required": [
                "confirmPassword",
                "email",
                "password"
            ],
            "properties": {
                "confirmPassword": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "types.Product": {
            "type": "object",
            "properties": {
                "budget": {
                    "type": "number"
                },
                "createdAt": {
                    "type": "string"
                },
                "deliverables": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "desciption": {
                    "type": "string"
                },
                "duration": {
                    "type": "integer",
                    "example": 3600000000000
                },
                "expiration": {
                    "type": "integer",
                    "example": 3600000000000
                },
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "imageUrl": {
                    "type": "string"
                },
                "skills": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "title": {
                    "type": "string"
                },
                "updatedAt": {
                    "type": "string"
                },
                "userId": {
                    "type": "string",
                    "format": "uuid"
                }
            }
        },
        "types.RegisterUserParams": {
            "type": "object",
            "required": [
                "email",
                "firstName",
                "lastName",
                "password",
                "role"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "firstName": {
                    "type": "string"
                },
                "lastName": {
                    "type": "string"
                },
                "password": {
                    "type": "string",
                    "maxLength": 130,
                    "minLength": 6
                },
                "role": {
                    "type": "string"
                }
            }
        },
        "types.UpdateProfileParams": {
            "type": "object",
            "properties": {
                "bio": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "firstName": {
                    "type": "string"
                },
                "lastName": {
                    "type": "string"
                },
                "profileImage": {
                    "type": "string"
                }
            }
        }
    }
